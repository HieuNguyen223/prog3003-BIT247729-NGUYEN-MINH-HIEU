import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.scene.Scene;
import javafx.scene.control.*;
import javafx.scene.layout.GridPane;
import javafx.stage.Stage;

public class Bai4_CongHaiSo extends Application {

    @Override
    public void start(Stage primaryStage) {
        Label lblSo1 = new Label("Số thứ nhất:");
        Label lblSo2 = new Label("Số thứ hai:");
        Label lblKetQua = new Label("Kết quả");
        
        TextField txtSo1 = new TextField();
        TextField txtSo2 = new TextField();
        Button btnTinhTong = new Button("Tính tổng");

        GridPane grid = new GridPane();
        grid.setPadding(new Insets(15));
        grid.setHgap(10);
        grid.setVgap(10);

        grid.add(lblSo1, 0, 0);
        grid.add(txtSo1, 1, 0);

        grid.add(lblSo2, 0, 1);
        grid.add(txtSo2, 1, 1);

        grid.add(btnTinhTong, 0, 2);
        grid.add(lblKetQua, 1, 2);

        btnTinhTong.setOnAction(e -> {
            try {
                double so1 = Double.parseDouble(txtSo1.getText());
                double so2 = Double.parseDouble(txtSo2.getText());
                double tong = so1 + so2;
                lblKetQua.setText("Kết quả: " + tong);
            } catch (NumberFormatException ex) {
                lblKetQua.setText("Lỗi!");
            }
        });

        Scene scene = new Scene(grid, 350, 180);
        primaryStage.setTitle("Máy Tính Cộng Hai Số");
        primaryStage.setScene(scene);
        primaryStage.show();
    }

    public static void main(String[] args) {
        launch(args);
    }
}
